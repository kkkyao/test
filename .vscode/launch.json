{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug run_episode",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/run_episode.py",
      "python": "/usr/bin/python3",
      "args": ["--config", "configs/config.yaml"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": false,
      "stopOnEntry": true
    }
  ]
}
